CompileFlags:
  # Point clangd at the compile_commands.json generated by CMake.
  # Run: cmake -S . -B build -DCMAKE_EXPORT_COMPILE_COMMANDS=ON
  # Then: ln -sf build/compile_commands.json compile_commands.json
  CompilationDatabase: build

Diagnostics:
  UnusedIncludes: Strict

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

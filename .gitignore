# CMake build tree
build/

# Build artifacts and pi-gen checkout (generated by build scripts)
deploy/

# clangd generated compile commands symlink
compile_commands.json

# Compiled object/library files
*.o
*.a
*.so

# Pi OS images (distributed as GitHub Release assets, not committed)
*.img
*.img.xz
*.img.gz
*.img.zst

# Claude Code local session data
.claude/

# OS cruft
.DS_Store
Thumbs.db

# Python (pi-gen uses some Python tooling)
__pycache__/
*.pyc
